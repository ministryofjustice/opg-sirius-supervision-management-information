{
  "name": "opg-sirius-supervision-management-information",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "build": "yarn build:js && yarn build:css",
    "build:js": "esbuild --bundle web/assets/main.js --minify --outfile=web/static/javascript/all.js --sourcemap --resolve-extensions=.mjs,.js",
    "build:css": "sass --load-path . --style compressed web/assets/main.scss web/static/stylesheets/all.css",
    "clean": "rm -rf web/static",
    "test": "cd internal && go test",
    "cypress": "cypress open",
    "cypress-ci": "cypress open -c baseUrl=http://localhost:8080",
    "lint": "eslint web/assets",
    "watch": "yarn build:css && yarn build:js --watch=forever"
  },
  "dependencies": {
    "@ministryofjustice/frontend": "^2.1.3",
    "govuk-frontend": "^5.4.1",
    "htmx.org": "^2.0.0",
    "opg-sirius-header": "ministryofjustice/opg-sirius-header#semver:v0.53.3"
  },
  "devDependencies": {
    "axe-core": "^4.9.1",
    "cypress": "^15.0.0",
    "cypress-axe": "^1.5.0",
    "cypress-failed-log": "^2.10.0",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "sass": "^1.77.8",
    "typescript": "^6.0.0"
  }
}
